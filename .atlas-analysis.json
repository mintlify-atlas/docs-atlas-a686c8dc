  "keyFeatures": [
    "API key creation, verification, and revocation with metadata and expiration",
    "Rate limiting with per-key, per-user, and per-endpoint limits",
    "Identity management for multi-tenant applications",
    "Usage tracking and analytics with credit limits and refills",
    "Role-based access control (RBAC) with permissions and roles",
    "Audit logging for compliance and security",
    "Global edge deployment with low-latency verification"
  ],
  "publicApiSurface": [
    "/v2/keys.create - Create a new API key",
    "/v2/keys.verify - Verify an API key",
    "/v2/keys.update - Update key metadata or settings",
    "/v2/keys.delete - Revoke an API key",
    "/v2/keys.list - List keys for an API",
    "/v2/keys.addPermissions - Add permissions to a key",
    "/v2/keys.addRoles - Add roles to a key",
    "/v2/apis.create - Create a new API",
    "/v2/apis.get - Get API details",
    "/v2/apis.delete - Delete an API",
    "/v2/ratelimit.limit - Check and decrement rate limit",
    "/v2/identities.create - Create an identity",
    "/v2/identities.get - Get identity details",
    "/v2/identities.update - Update identity metadata",
    "/v2/identities.delete - Delete an identity",
    "/v2/identities.list - List identities",
    "/v2/analytics.getVerifications - Query verification analytics"
  ]
